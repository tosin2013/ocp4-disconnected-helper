# dnsmasq configuration for OpenShift cluster: {{ cluster_name }}.{{ base_domain }}
# Generated by openshift_cluster_deploy role
# Do not edit manually - managed by Ansible

# API Endpoint
address=/api.{{ cluster_name }}.{{ base_domain }}/{{ api_vip }}

# Apps Wildcard (Ingress)
address=/.apps.{{ cluster_name }}.{{ base_domain }}/{{ ingress_vip }}

{% if cluster_topology == 'sno' %}
# SNO Node (combined control plane + worker)
address=/{{ cluster_name }}.{{ base_domain }}/{{ api_vip }}
{% endif %}

{% if control_plane_nodes is defined %}
# Control Plane Nodes
{% for node in control_plane_nodes %}
address=/{{ node.name }}.{{ cluster_name }}.{{ base_domain }}/{{ node.ip }}
{% endfor %}
{% endif %}

{% if worker_nodes is defined %}
# Worker Nodes
{% for node in worker_nodes %}
address=/{{ node.name }}.{{ cluster_name }}.{{ base_domain }}/{{ node.ip }}
{% endfor %}
{% endif %}

# Additional DNS settings
{% if dns_upstream_servers is defined %}
# Upstream DNS servers for recursive queries
{% for server in dns_upstream_servers %}
server={{ server }}
{% endfor %}
{% endif %}

# Cache settings
cache-size={{ dns_cache_size | default(1000) }}

# Log DNS queries (for debugging)
{% if dns_enable_logging | default(false) %}
log-queries
log-facility=/var/log/dnsmasq-{{ cluster_name }}.log
{% endif %}
