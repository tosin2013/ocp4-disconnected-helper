    default_backend aap_backend

backend aap_backend
    mode http
    balance roundrobin
    option httpchk GET /api/v2/ping/
    http-check expect status 200
    server aap {{ aap_vm_ip }}:{{ aap_vm_port }} check ssl verify none

#---------------------------------------------------------------------
# OpenShift API Frontend (Port {{ ocp_api_external_port }})
#---------------------------------------------------------------------
frontend ocp_api_front
    bind *:{{ ocp_api_external_port }}
    mode tcp
    option tcplog
