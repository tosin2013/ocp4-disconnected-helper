    server jfrog {{ jfrog_vm_ip }}:{{ jfrog_docker_port }} check

#---------------------------------------------------------------------
# AAP Controller Frontend (Port {{ aap_external_port }})
#---------------------------------------------------------------------
frontend aap_front
    bind *:{{ aap_external_port }} ssl crt /etc/haproxy/certs/selfsigned.pem
