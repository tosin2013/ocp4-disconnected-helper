# AAP 2.6 Multi-Node Inventory
# Generated by: playbooks/deploy-aap-multi-node.yml
# Deployment Topology: Gateway + Controller + Database (3 nodes)

[automationgateway]
{{ hostvars['aap-gateway'].vm_static_ip }} ansible_connection=local

[automationcontroller]
{{ hostvars['aap-controller'].vm_static_ip }}

[database]
{{ hostvars['aap-database'].vm_static_ip }}

[all:vars]
# Red Hat Registry Credentials
registry_url='registry.redhat.io'
registry_username='{{ registry_username }}'
registry_password='{{ registry_password }}'

# Redis Configuration
redis_mode='standalone'

# AAP Gateway Configuration
automationgateway_admin_password='{{ automationgateway_admin_password }}'
automationgateway_pg_host={{ hostvars['aap-database'].vm_static_ip }}
automationgateway_pg_port=5432
automationgateway_pg_database='automationgateway'
automationgateway_pg_username='automationgateway'
automationgateway_pg_password='{{ automationgateway_pg_password }}'
automationgateway_pg_sslmode='prefer'

# AAP Controller Configuration
admin_password='{{ admin_password }}'
pg_host={{ hostvars['aap-database'].vm_static_ip }}
pg_port=5432
pg_database='awx'
pg_username='awx'
pg_password='{{ pg_password }}'
pg_sslmode='prefer'

# PostgreSQL Admin Password (for database node)
postgresql_admin_password='{{ postgresql_admin_password }}'
