#cloud-config
# Cloud-init user-data for Registry VM
# Generated by ocp4-disconnected-helper

hostname: {{ vm_hostname }}
fqdn: {{ vm_fqdn }}
manage_etc_hosts: true

users:
  - name: {{ vm_user }}
    groups: wheel
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    lock_passwd: false
    ssh_authorized_keys:
      - {{ ssh_public_key }}

  - name: root
    lock_passwd: true
    ssh_authorized_keys:
      - {{ ssh_public_key }}

# Install packages required for container registry
packages:
  - podman
  - firewalld
  - openssl
  - curl
  - wget
  - tar
  - jq
  - python3
  - python3-pip

# Configure firewall and services
runcmd:
  # Enable firewalld
  - systemctl enable --now firewalld

  # Enable podman socket for API access
  - systemctl enable --now podman.socket

  # Open registry port (5000 for mirror-registry/Quay)
  - firewall-cmd --permanent --add-port=5000/tcp
  - firewall-cmd --permanent --add-port=8443/tcp
  - firewall-cmd --reload

  # Create registry directories
  - mkdir -p /opt/registry/data
  - mkdir -p /opt/registry/auth
  - mkdir -p /opt/registry/certs
  - chown -R {{ vm_user }}:{{ vm_user }} /opt/registry

  # Mark VM as ready
  - echo "Registry VM ready" > /var/log/registry-vm-ready
  - date >> /var/log/registry-vm-ready

# Write files
write_files:
  - path: /etc/sysctl.d/99-registry.conf
    content: |
      # Increase file descriptors for container registry
      fs.file-max = 2097152
      fs.inotify.max_user_watches = 524288
      fs.inotify.max_user_instances = 512
    permissions: '0644'

# Final message
final_message: "Registry VM {{ vm_fqdn }} is ready after $UPTIME seconds"
