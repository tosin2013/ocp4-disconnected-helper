---
# Red Hat Subscription Management Credentials (Activation Key Method)
#
# INSTRUCTIONS:
# 1. Copy this file: cp rhel-subscription-secrets.yml.example rhel-subscription-secrets.yml
# 2. Fill in your values (get from: https://access.redhat.com/management/activation_keys)
# 3. Encrypt: ansible-vault encrypt rhel-subscription-secrets.yml
# 4. Save vault password: echo "YOUR_VAULT_PASSWORD" > ~/.vault_pass && chmod 600 ~/.vault_pass
#
# USAGE:
# ansible-playbook -i inventory/ibm-cloud.yml playbooks/deploy-aap.yml \
#   --vault-password-file ~/.vault_pass \
#   -e @extra_vars/rhel-subscription-secrets.yml

# ============================================================
# REQUIRED: Red Hat Organization ID
# ============================================================
# Find at: https://access.redhat.com/management/activation_keys
# Example: 1234567
rhsm_org_id: "YOUR_ORG_ID_HERE"

# ============================================================
# REQUIRED: Activation Key Name
# ============================================================
# Create at: https://access.redhat.com/management/activation_keys
# Recommended naming: aap-rhel9-automation
# Example: aap-rhel9-key
rhsm_activationkey: "YOUR_ACTIVATION_KEY_HERE"

# ============================================================
# REQUIRED: Red Hat API Offline Token (for AAP installer download)
# ============================================================
# Generate at: https://access.redhat.com/management/api/
# Guide: https://access.redhat.com/articles/3626371
# This token allows downloading AAP installer from Red Hat APIs
aap_setup_down_offline_token: "YOUR_OFFLINE_TOKEN_HERE"

# ============================================================
# REQUIRED: Red Hat Registry Credentials (for AAP 2.6 Installation)
# ============================================================
# Option 1: Red Hat Customer Portal Account
# Username: Your Red Hat login email
# Password: Your Red Hat Customer Portal password
registry_username: "your-redhat-email@example.com"
registry_password: "your-redhat-portal-password"

# Option 2: Red Hat Service Account (Recommended for automation)
# Create at: https://access.redhat.com/terms-based-registry/
# Guide: https://access.redhat.com/RegistryAuthentication
# registry_username: "12345678|your-service-account-name"
# registry_password: "eyJhbGciOiJSUzUxMiJ9..." # Service account token

# ============================================================
# REQUIRED: AAP 2.6 Multi-Node Admin Passwords
# ============================================================
# CRITICAL: AAP 2.6 multi-node uses TWO separate admin passwords:
#
#   1. automationgateway_admin_password - For WEB UI login
#      Access: https://aap.sandbox3377.opentlc.com
#      Username: admin
#      Password: <value below>
#
#   2. admin_password - For CONTROLLER API authentication
#      Access: curl -u admin:<password> https://aap.../api/controller/v2/ping/
#      Usage: API automation, CLI tools
#
# ⚠️ DO NOT use the same password for both components.
# See: docs/adrs/0028-aap-multi-node-password-architecture.md
# ============================================================

# AAP Gateway Admin Password (Web UI Login)
automationgateway_admin_password: "YourSecureGatewayPassword123!"

# AAP Controller Admin Password (API Authentication)
admin_password: "YourSecureControllerPassword123!"

# ============================================================
# REQUIRED: PostgreSQL Passwords
# ============================================================
# Gateway PostgreSQL Password
automationgateway_pg_password: "YourSecureGatewayPgPassword123!"

# Controller PostgreSQL Password
pg_password: "YourSecureControllerPgPassword123!"

# PostgreSQL Admin Password (for database server)
postgresql_admin_password: "YourSecurePostgresAdminPassword123!"

# ============================================================
# OPTIONAL: Override Auto-Attach
# ============================================================
# Default: true (automatically attach available subscriptions)
# rhsm_auto_attach: true

# ============================================================
# OPTIONAL: Force Re-registration
# ============================================================
# Default: false (skip if already registered)
# Useful for testing or fixing broken registrations
# rhsm_force_register: false

# ============================================================
# REQUIRED: Quay.io Registry Credentials (for Custom AAP Execution Environment)
# ============================================================
# ADR 0029: Custom execution environment with registry.redhat.io authentication
#
# ✅ RECOMMENDED: Use Quay robot account for automation
# See: docs/QUAY_ROBOT_ACCOUNT_SETUP.md
#
# Option 1: Robot Account (Recommended for automation)
# Format: {username}+{robot_name}
# Example: takinosh+aap_builder
quay_username: "your-quay-username+robot_name"

# Robot Token (NOT a password - long JWT-like string from Quay UI)
# Generate: Quay UI → Repository Settings → Robot Accounts → Create
quay_password: "eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIs..."

# Option 2: Personal Account (Not recommended for automation)
# quay_username: "your-quay-username"
# quay_password: "your-quay-account-password"

# Quay API Token (for API operations - optional)
# Generate at: https://quay.io/organization/<org>/application
# quay_api_token: "your-quay-api-token"

# Optional: Separate robot for AAP pulls (read-only, more secure)
# aap_quay_username: "your-quay-username+aap_puller"
# aap_quay_password: "PULLER_ROBOT_TOKEN"

# Custom EE Image Name (default: quay.io/{username}/ocp4-aap-execution-environment)
# ee_image_name: "quay.io/takinosh/ocp4-aap-execution-environment"
# ee_image_tag: "latest"
